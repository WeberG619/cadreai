# Required
GOOGLE_API_KEY=your-api-key-here

# Agent model (default: gemini-2.5-flash)
# Use gemini-2.5-flash-native-audio-latest for voice mode
CADRE_MODEL=gemini-2.5-flash

# Revit integration (set to false for cloud deployment)
REVIT_ENABLED=true

# Server port (Cloud Run sets this automatically)
PORT=8443

# Optional: Vertex AI (alternative to API key)
# GOOGLE_CLOUD_PROJECT=your-project-id
# GOOGLE_CLOUD_LOCATION=us-central1

# Optional: enhanced data sources
# FINNHUB_API_KEY=your-key
# ALPHA_VANTAGE_KEY=your-key
# FRED_API_KEY=your-key
# GOOGLE_CSE_ID=your-custom-search-engine-id
